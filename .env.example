# Copy this file to .env.local and fill in real values.
# Do not commit .env.local or any file with real credentials.

# PostgreSQL connection strings (Supabase)
# DATABASE_URL = pooled connection (use with connection pooler, e.g. port 6543)
# DIRECT_URL   = direct connection for Prisma migrations (port 5432)
DATABASE_URL=
DIRECT_URL=

# NextAuth configuration (Phase 1: only admin authentication)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Resend API key for transactional emails
RESEND_API_KEY=

# Stripe keys for B2C payments (Phase 1)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Public procurement / contact form notification emails
ADMIN_EMAIL=
COMMERCIAL_MANAGER_EMAIL=
